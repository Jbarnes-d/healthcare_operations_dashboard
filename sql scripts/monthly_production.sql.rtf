/*
Purpose:
Retrieve monthly production totals for dashboard reporting.

Privacy Note:
This is a sanitized portfolio version of the original query.
Practice-specific identifiers and confidential fields have been removed.
*/

SELECT\
    DATE_FORMAT(ProcDate, '%Y-%m') AS Month,\
    SUM(ProcFee) AS Production\
FROM procedurelog\
WHERE YEAR(ProcDate) IN (2025, 2026)\
    AND ProcStatus = 2\
GROUP BY Month\
ORDER BY Month;}
