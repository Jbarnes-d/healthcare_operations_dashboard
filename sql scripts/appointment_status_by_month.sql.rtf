SELECT\
    YEAR(AptDateTime) AS ApptYear,\
    MONTH(AptDateTime) AS ApptMonth,\
    AptStatus,\
    COUNT(*) AS AppointmentCount\
FROM appointment\
WHERE AptDateTime >= '2025-01-01'\
GROUP BY\
    YEAR(AptDateTime),\
    MONTH(AptDateTime),\
    AptStatus\
ORDER BY\
    ApptYear,\
    ApptMonth,\
    AptStatus;}
